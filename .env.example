# Copy this file to .env and set the paths for your machine.

# Path to your unpacked Ableton Extensions SDK.
# Default: ./sdk/extensions-sdk-1.0.0-beta.0 (place the SDK zip contents here)
ABLETON_SDK_PATH=./sdk/extensions-sdk-1.0.0-beta.0

# Path to the Ableton Live app whose Extension Host to launch (.app on macOS).
# Path to Ableton Live 12 Beta (.app on macOS). Must support Extensions.
# Live 12 Suite (non-beta) does NOT include ExtensionHost — use the Beta app.
EXTENSION_HOST_PATH=/Applications/Ableton Live 12 Beta.app
