{
  "name": "neural-midi",
  "version": "0.1.0",
  "description": "On-device ML melody generation for Ableton Live",
  "license": "MIT",
  "type": "module",
  "main": "dist/extension.js",
  "engines": {
    "node": ">=24.16.0"
  },
  "scripts": {
    "setup": "node scripts/setup-sdk.mjs && npm install",
    "train": "python training/download_data.py --max-files 200 && python training/train_melody.py --epochs 8",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && tsx build.ts",
    "build:prod": "npm run typecheck && tsx build.ts --production",
    "start": "npm run build && node scripts/dev-preflight.mjs && extensions-cli run --storage-directory \"$PWD/.dev/storage\" --temp-directory \"$PWD/.dev/temp\"",
    "package": "npm run build:prod && node scripts/package.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@ableton-extensions/sdk": "file:vendor/ableton-extensions-sdk.tgz"
  },
  "devDependencies": {
    "@ableton-extensions/cli": "file:vendor/ableton-extensions-cli.tgz",
    "@types/node": "^24.1.0",
    "esbuild": "0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  },
  "optionalDependencies": {
    "onnxruntime-node": "^1.21.0"
  }
}
